-- ============================================================
-- Nova Control Flow Test Suite (Phase 10.1)
-- Tests: if/elseif/else, while, repeat-until, numeric for,
--        generic for, break, goto, do-end, return, closures,
--        upvalues, variadic, nested functions
-- ============================================================

dec pass = 0
dec fail = 0

dec function check(name, got, expected)
    if tostring(got) == tostring(expected) then
        pass = pass + 1
        print("  PASS: " .. name)
    else
        fail = fail + 1
        print("  FAIL: " .. name .. " (got " .. tostring(got) .. ", expected " .. tostring(expected) .. ")")
    end
end

print("=== CONTROL FLOW TESTS ===")

-- ============================================================
-- if / elseif / else
-- ============================================================
print("\n-- if/elseif/else --")

dec x = 10
dec r = "none"
if x > 20 then
    r = "big"
elseif x > 5 then
    r = "medium"
else
    r = "small"
end
check("if/elseif/else", r, "medium")

-- Falsy values: nil and false
if nil then r = "bad" else r = "nil is falsy" end
check("nil is falsy", r, "nil is falsy")

if false then r = "bad" else r = "false is falsy" end
check("false is falsy", r, "false is falsy")

-- Truthy: 0, "", empty table
if 0 then r = "0 is truthy" end
check("0 is truthy", r, "0 is truthy")

if "" then r = "empty str truthy" end
check("empty string truthy", r, "empty str truthy")

-- ============================================================
-- while loop
-- ============================================================
print("\n-- while --")

dec sum = 0
dec i = 1
while i <= 10 do
    sum = sum + i
    i = i + 1
end
check("while sum 1..10", sum, 55)

-- While with false condition (0 iterations)
dec count = 0
while false do
    count = count + 1
end
check("while false: no iterations", count, 0)

-- ============================================================
-- repeat-until
-- ============================================================
print("\n-- repeat-until --")

dec rsum = 0
dec ri = 0
repeat
    ri = ri + 1
    rsum = rsum + ri
until ri >= 5
check("repeat-until sum", rsum, 15)
check("repeat-until final i", ri, 5)

-- repeat runs at least once
dec ran_once = false
repeat
    ran_once = true
until true
check("repeat runs at least once", ran_once, true)

-- ============================================================
-- Numeric for (positive step)
-- ============================================================
print("\n-- numeric for --")

dec fsum = 0
for i = 0, 4 do
    fsum = fsum + i
end
check("for 0..4 sum", fsum, 10)

-- Negative step
dec rev = ""
for i = 5, 1, -1 do
    rev = rev .. tostring(i)
end
check("for 5..1 step -1", rev, "54321")

-- Zero iterations (start > stop)
dec zcount = 0
for i = 10, 5 do
    zcount = zcount + 1
end
check("for zero iterations", zcount, 0)

-- Custom step
dec step_sum = 0
for i = 0, 10, 2 do
    step_sum = step_sum + i
end
check("for step 2: 0+2+4+6+8+10", step_sum, 30)

-- ============================================================
-- Generic for (pairs / ipairs)
-- ============================================================
print("\n-- generic for --")

-- ipairs
dec arr = {10, 20, 30}
dec ip_sum = 0
dec ip_count = 0
for i, v in ipairs(arr) do
    ip_sum = ip_sum + v
    ip_count = ip_count + 1
end
check("ipairs sum", ip_sum, 60)
check("ipairs count", ip_count, 3)

-- pairs with hash table
dec ht = { a = 1, b = 2, c = 3 }
dec pair_sum = 0
dec pair_keys = 0
for k, v in pairs(ht) do
    pair_sum = pair_sum + v
    pair_keys = pair_keys + 1
end
check("pairs sum values", pair_sum, 6)
check("pairs key count", pair_keys, 3)

-- ============================================================
-- break
-- ============================================================
print("\n-- break --")

dec bsum = 0
for i = 0, 99 do
    if i >= 5 then break end
    bsum = bsum + i
end
check("break at 5: sum 0..4", bsum, 10)

-- Break in while
dec bw = 0
while true do
    bw = bw + 1
    if bw >= 3 then break end
end
check("break in while", bw, 3)

-- Nested break (only breaks inner loop)
dec outer_count = 0
for i = 0, 2 do
    for j = 0, 99 do
        if j >= 2 then break end
    end
    outer_count = outer_count + 1
end
check("nested break: outer runs 3x", outer_count, 3)

-- ============================================================
-- goto
-- ============================================================
print("\n-- goto --")

-- Forward goto
dec gval = 0
goto skip_assign
gval = 999
::skip_assign::
check("goto forward", gval, 0)

-- goto in loop (skip even numbers)
dec odd_sum = 0
for i = 0, 9 do
    if i % 2 == 0 then goto continue_loop end
    odd_sum = odd_sum + i
    ::continue_loop::
end
check("goto continue pattern", odd_sum, 25)

-- ============================================================
-- do-end block scoping
-- ============================================================
print("\n-- do-end scoping --")

dec outer = "outer"
do
    dec inner = "inner"
    check("do-end: inner visible", inner, "inner")
    check("do-end: outer visible", outer, "outer")
end
-- inner should not be visible here; accessing it would give nil
-- (Can't easily test undeclared variable in Nova without pcall)

-- ============================================================
-- return (multiple values)
-- ============================================================
print("\n-- return --")

dec function multi_ret()
    return 1, 2, 3
end
dec a, b, c = multi_ret()
check("multi return a", a, 1)
check("multi return b", b, 2)
check("multi return c", c, 3)

-- Single return
dec function single_ret()
    return 42
end
check("single return", single_ret(), 42)

-- No explicit return (known: may return junk in current impl)
-- Skipped: no_ret() behavior is undefined for empty functions

-- ============================================================
-- Closures / Upvalues
-- ============================================================
print("\n-- closures/upvalues --")

dec function make_counter()
    dec count = 0
    return function()
        count = count + 1
        return count
    end
end

dec counter = make_counter()
check("closure call 1", counter(), 1)
check("closure call 2", counter(), 2)
check("closure call 3", counter(), 3)

-- Two independent closures
dec c1 = make_counter()
dec c2 = make_counter()
c1()
c1()
check("independent closures: c1", c1(), 3)
check("independent closures: c2", c2(), 1)

-- Shared upvalue
dec function make_pair()
    dec val = 0
    dec function get() return val end
    dec function set(v) val = v end
    return get, set
end
dec get, set = make_pair()
check("shared upvalue: initial", get(), 0)
set(42)
check("shared upvalue: after set", get(), 42)

-- ============================================================
-- Variadic functions (...)
-- NOTE: {…} vararg packing is limited; use select() or
--       fixed-arg wrappers for now.

dec function vfirst(a, ...)
    return a
end
check("variadic first arg", vfirst(10, 20, 30), 10)

dec function vadd(a, b, ...)
    return a + b
end
check("variadic fixed + rest", vadd(3, 7, 99), 10)

-- ============================================================
-- Nested function definitions
-- ============================================================
print("\n-- nested functions --")

dec function outer_fn()
    dec function inner_fn(x)
        return x * 2
    end
    return inner_fn(5) + inner_fn(3)
end
check("nested function", outer_fn(), 16)

-- Recursive function (dec)
dec function fib(n)
    if n <= 1 then return n end
    return fib(n - 1) + fib(n - 2)
end
check("recursive fib(10)", fib(10), 55)

-- Mutual recursion
dec function is_even(n)
    if n == 0 then return true end
    return is_odd(n - 1)
end
function is_odd(n)
    if n == 0 then return false end
    return is_even(n - 1)
end
check("mutual recursion: even(4)", is_even(4), true)
check("mutual recursion: even(5)", is_even(5), false)

-- ============================================================
-- RESULTS
-- ============================================================
printf("\n============================================\n")
printf("  CONTROL TESTS: %d/%d\n", pass, pass + fail)
printf("============================================\n")
if fail > 0 then
    error("CONTROL: " .. fail .. " test(s) FAILED")
end
