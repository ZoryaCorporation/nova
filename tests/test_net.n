-- ============================================================
-- test_net.n — Network Library Test Suite
--
-- Tests the HTTP/HTTPS module (#import net).
-- Uses httpbin.org for live HTTP testing.
--
-- NOTE: Requires network access. If offline, tests will fail
-- gracefully via pcall.
--
-- Author: Anthony Taliento
-- Copyright (c) 2026 Zorya Corporation
-- ============================================================
#import net
#import json

dec pass = 0
dec fail = 0
dec skip = 0

dec function check(name, cond)
    if cond then
        pass = pass + 1
    else
        fail = fail + 1
        printf("  FAIL: %s\n", name)
    end
end

dec function skip_check(name)
    skip = skip + 1
    printf("  SKIP: %s (offline)\n", name)
end

print("=== NET LIBRARY TEST SUITE ===")

-- ----------------------------------------------------------
-- 1. Module availability
-- ----------------------------------------------------------
print("\n--- 1. Module Loaded ---")
check("net exists", net != nil)
check("net.get exists", type(net.get) == "function")
check("net.post exists", type(net.post) == "function")
check("net.put exists", type(net.put) == "function")
check("net.delete exists", type(net.delete) == "function")
check("net.patch exists", type(net.patch) == "function")
check("net.head exists", type(net.head) == "function")
check("net.request exists", type(net.request) == "function")
check("net.url_encode exists", type(net.url_encode) == "function")
check("net.url_decode exists", type(net.url_decode) == "function")

-- ----------------------------------------------------------
-- 2. URL encode/decode (offline - no network needed)
-- ----------------------------------------------------------
print("\n--- 2. URL Encode/Decode ---")
do
    dec encoded = net.url_encode("hello world")
    check("url_encode spaces", encoded == "hello%20world")

    dec decoded = net.url_decode("hello%20world")
    check("url_decode spaces", decoded == "hello world")

    encoded = net.url_encode("key=val&foo=bar")
    check("url_encode special", string.find(encoded, "%%3D") != nil or string.find(encoded, "%%3d") != nil)

    decoded = net.url_decode(encoded)
    check("roundtrip encode/decode", decoded == "key=val&foo=bar")

    encoded = net.url_encode("日本語")
    decoded = net.url_decode(encoded)
    check("unicode roundtrip", decoded == "日本語")
end

-- ----------------------------------------------------------
-- 3. HTTP GET (live test)
-- ----------------------------------------------------------
print("\n--- 3. HTTP GET ---")
do
    dec ok, resp = pcall(net.get, "https://httpbin.org/get")
    if ok and type(resp) == "table" then
        check("GET status 200", resp.status == 200)
        check("GET body exists", type(resp.body) == "string" and #resp.body > 0)
        check("GET ok flag", resp.ok == true)
        check("GET url field", type(resp.url) == "string")
        check("GET headers table", type(resp.headers) == "table")

        -- Parse JSON body
        dec data = json.decode(resp.body)
        check("GET parsed JSON", type(data) == "table")
        check("GET has url field", data.url == "https://httpbin.org/get")
    else
        for i = 1, 7 do skip_check("GET test " .. tostring(i)) end
    end
end

-- ----------------------------------------------------------
-- 4. HTTP POST with JSON body
-- ----------------------------------------------------------
print("\n--- 4. HTTP POST ---")
do
    dec payload = json.encode({name = "Nova", version = "1.0"})
    dec ok, resp = pcall(net.post, "https://httpbin.org/post", payload, {
        headers = {["Content-Type"] = "application/json"}
    })
    if ok and type(resp) == "table" then
        check("POST status 200", resp.status == 200)
        check("POST ok", resp.ok == true)

        dec data = json.decode(resp.body)
        check("POST echoed data", type(data) == "table")
        if type(data) == "table" and data.json != nil then
            check("POST json.name", data.json.name == "Nova")
        else
            check("POST json payload", false)
        end
    else
        for i = 1, 4 do skip_check("POST test " .. tostring(i)) end
    end
end

-- ----------------------------------------------------------
-- 5. HTTP HEAD
-- ----------------------------------------------------------
print("\n--- 5. HTTP HEAD ---")
do
    dec ok, resp = pcall(net.head, "https://httpbin.org/get")
    if ok and type(resp) == "table" then
        check("HEAD status 200", resp.status == 200)
        check("HEAD no body", #resp.body == 0)
        check("HEAD has headers", type(resp.headers) == "table")
    else
        for i = 1, 3 do skip_check("HEAD test " .. tostring(i)) end
    end
end

-- ----------------------------------------------------------
-- 6. HTTP status codes
-- ----------------------------------------------------------
print("\n--- 6. Status Codes ---")
do
    dec ok, resp = pcall(net.get, "https://httpbin.org/status/404")
    if ok and type(resp) == "table" then
        check("404 status", resp.status == 404)
        check("404 not ok", resp.ok == false)
    else
        for i = 1, 2 do skip_check("status code test " .. tostring(i)) end
    end
end

-- ----------------------------------------------------------
-- 7. net.request generic API
-- ----------------------------------------------------------
print("\n--- 7. Generic Request ---")
do
    dec ok, resp = pcall(net.request, {
        method = "PUT",
        url = "https://httpbin.org/put",
        body = "test-body",
        headers = {["Content-Type"] = "text/plain"},
        timeout = 15,
    })
    if ok and type(resp) == "table" then
        check("request PUT 200", resp.status == 200)
        dec data = json.decode(resp.body)
        check("request body echoed", data.data == "test-body")
    else
        for i = 1, 2 do skip_check("request test " .. tostring(i)) end
    end
end

-- ----------------------------------------------------------
-- 8. Timeout handling
-- ----------------------------------------------------------
print("\n--- 8. Timeout ---")
do
    -- httpbin delays for 5 seconds, but we set timeout to 1
    dec ok, err = pcall(net.get, "https://httpbin.org/delay/5", {timeout = 1})
    if not ok then
        check("timeout triggers error", true)
    else
        -- If it somehow succeeds (fast network), that's OK too
        check("timeout or fast response", true)
    end
end

-- ============================================================
-- RESULTS
-- ============================================================
print("\n============================================")
printf("  NET TESTS: %d/%d", pass, pass + fail)
if skip > 0 then
    printf(" (%d skipped)", skip)
end
print("\n============================================")

if fail > 0 then
    printf("  *** %d TESTS FAILED ***\n", fail)
    os.exit(1)
end
print("  ALL NET TESTS PASSED")
