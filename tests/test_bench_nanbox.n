banner("RESULTS SUMMARY")
-- ██████████████████████████████████████████████████████████

dec total_elapsed = os.clock() - total_start

printf("\n")
printf("    NovaValue size: 8 bytes (NaN-boxed uint64_t)\n")
printf("    Total benchmarks: %d passed, %d failed\n", pass, fail)
printf("    Total time: %.3f seconds\n", total_elapsed)
printf("\n")

if fail == 0 then
    printf("    ALL CHECKS PASSED\n")
else
    printf("    *** %d FAILURES ***\n", fail)
end

printf("\n")
printf("    Compare Part A results against baselines from\n")
printf("    NOVA_PERFORMANCE_REPORT.md (pre-NaN-boxing).\n")
printf("    [++] = faster  [==] = same  [--] = slower\n")
printf("\n")
