-- Extended benchmarks for performance report

echo("========================================")
echo("  NOVA VM EXTENDED BENCHMARKS")
echo("========================================")
echo("")

-- 1. Function call overhead
echo("--- FUNCTION CALLS ---")
do
    dec c = 0
    dec function inc() c = c + 1 end
    dec s = os.clock()
    for i = 0, 999999 do inc() end
    dec e = os.clock() - s
    printf("  1M function calls:                 %8.4f sec  (%.1fM/sec)\n", e, 1.0/e)
end

do
    dec c = 0
    dec function inc() c = c + 1 end
    dec s = os.clock()
    for i = 0, 4999999 do inc() end
    dec e = os.clock() - s
    printf("  5M function calls:                 %8.4f sec  (%.1fM/sec)\n", e, 5.0/e)
end

-- 2. Loop throughput
echo("")
echo("--- LOOP THROUGHPUT ---")
do
    dec s = os.clock()
    dec sum = 0
    for i = 0, 999999 do sum = sum + i end
    dec e = os.clock() - s
    printf("  1M numeric for-loop:               %8.4f sec  (%.1fM iter/sec)\n", e, 1.0/e)
end

do
    dec s = os.clock()
    dec sum = 0
    dec i = 0
    while i < 1000000 do sum = sum + i; i = i + 1 end
    dec e = os.clock() - s
    printf("  1M while loop:                     %8.4f sec  (%.1fM iter/sec)\n", e, 1.0/e)
end

-- 3. Table operations
echo("")
echo("--- TABLE OPERATIONS ---")
do
    dec t = {}
    dec s = os.clock()
    for i = 0, 99999 do t[i] = i * 2 end
    dec e = os.clock() - s
    printf("  100K int-key inserts:              %8.4f sec  (%.1fM/sec)\n", e, 0.1/e)
end

do
    dec t = {}
    for i = 0, 99999 do t[i] = i end
    dec s = os.clock()
    dec sum = 0
    for i = 0, 99999 do sum = sum + t[i] end
    dec e = os.clock() - s
    printf("  100K int-key lookups:              %8.4f sec  (%.1fM/sec)\n", e, 0.1/e)
end

do
    dec t = {}
    dec s = os.clock()
    for i = 0, 9999 do
        t[i] = { x = i, y = i * 2, z = i * 3 }
    end
    dec e = os.clock() - s
    printf("  10K table-of-tables build:         %8.4f sec\n", e)
end

-- 4. String operations
echo("")
echo("--- STRING OPERATIONS ---")
do
    dec s = os.clock()
    for i = 0, 49999 do
        dec x = "key_" .. tostring(i)
    end
    dec e = os.clock() - s
    printf("  50K string concatenations:         %8.4f sec  (%.1fK/sec)\n", e, 50.0/e)
end

do
    dec s = os.clock()
    for i = 0, 9999 do
        dec x = string.format("row_%05d_col_%03d", i, i % 100)
    end
    dec e = os.clock() - s
    printf("  10K sprintf format:                %8.4f sec  (%.1fK/sec)\n", e, 10.0/e)
end

-- 5. Recursion
echo("")
echo("--- RECURSION ---")
do
    dec function fib(n)
        if n < 2 then return n end
        return fib(n - 1) + fib(n - 2)
    end
    dec s = os.clock()
    dec r = fib(30)
    dec e = os.clock() - s
    printf("  fib(30) naive recursive:           %8.4f sec  (result=%d)\n", e, r)
end

do
    dec function fib(n)
        if n < 2 then return n end
        return fib(n - 1) + fib(n - 2)
    end
    dec s = os.clock()
    dec r = fib(35)
    dec e = os.clock() - s
    printf("  fib(35) naive recursive:           %8.4f sec  (result=%d)\n", e, r)
end

-- 6. GC pressure
echo("")
echo("--- GC PRESSURE ---")
do
    dec s = os.clock()
    for i = 0, 99999 do
        dec a = i + 1
        dec b = i + 2
        dec t = { i, a, b }
    end
    dec e = os.clock() - s
    printf("  100K temp tables (GC churn):       %8.4f sec  (%.1fK/sec)\n", e, 100.0/e)
end

-- 7. Matrix
echo("")
echo("--- MATRIX ---")
do
    dec N = 50
    dec A = {}
    dec B = {}
    for i = 0, N-1 do
        A[i] = {}; B[i] = {}
        for j = 0, N-1 do
            A[i][j] = (i+j) % 7
            B[i][j] = (i*j+1) % 5
        end
    end
    dec s = os.clock()
    dec C = {}
    for i = 0, N-1 do
        C[i] = {}
        for j = 0, N-1 do
            dec sum = 0
            for k = 0, N-1 do
                sum = sum + A[i][k] * B[k][j]
            end
            C[i][j] = sum
        end
    end
    dec e = os.clock() - s
    printf("  50x50 matmul:                      %8.4f sec\n", e)
end

do
    dec N = 100
    dec A = {}
    dec B = {}
    for i = 0, N-1 do
        A[i] = {}; B[i] = {}
        for j = 0, N-1 do
            A[i][j] = (i+j) % 7
            B[i][j] = (i*j+1) % 5
        end
    end
    dec s = os.clock()
    dec C = {}
    for i = 0, N-1 do
        C[i] = {}
        for j = 0, N-1 do
            dec sum = 0
            for k = 0, N-1 do
                sum = sum + A[i][k] * B[k][j]
            end
            C[i][j] = sum
        end
    end
    dec e = os.clock() - s
    printf("  100x100 matmul:                    %8.4f sec\n", e)
end

-- 8. Sieve
echo("")
echo("--- PRIMES ---")
do
    dec s = os.clock()
    dec SIZE = 100000
    dec sieve = {}
    for i = 0, SIZE do sieve[i] = true end
    sieve[0] = false; sieve[1] = false
    dec i = 2
    while i * i <= SIZE do
        if sieve[i] then
            dec j = i * i
            while j <= SIZE do sieve[j] = false; j = j + i end
        end
        i = i + 1
    end
    dec count = 0
    for k = 0, SIZE do if sieve[k] then count = count + 1 end end
    dec e = os.clock() - s
    printf("  Sieve to 100K:                     %8.4f sec  (primes=%d)\n", e, count)
end

echo("")
echo("========================================")
