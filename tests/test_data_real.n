-- ==========================================================
-- test_data_real.n - Real-World Data Processing Tests
--
-- Tests all 7 NDP codecs (JSON, CSV, TSV, INI, TOML, HTML,
-- YAML) with realistic multi-record data sets. Exercises
-- round-trip encode/decode, cross-format conversion, edge
-- cases, and the data.* meta-API.
--
-- Copyright (c) 2026 Zorya Corporation
-- ==========================================================

#import data

dec pass = 0
dec fail = 0

dec function check(name, cond)
    if cond then
        pass = pass + 1
        printf("  PASS: %s\n", name)
    else
        fail = fail + 1
        printf("  FAIL: %s\n", name)
    end
end

-- ==========================================================
-- 1. JSON: Complex Nested Object
-- ==========================================================
print("=== JSON: Complex Data ===")

do
    dec pkg = json.decode('{"name":"nova","version":"0.1.0","dependencies":{"nxh":"^1.0","dagger":"^2.3"},"scripts":{"build":"make","test":"make test"},"keywords":["language","vm","compiler"],"author":{"name":"Anthony","email":"anthony@zorya.dev"},"license":"MIT"}')

    check("json pkg.name", pkg.name == "nova")
    check("json pkg.version", pkg.version == "0.1.0")
    check("json pkg.license", pkg.license == "MIT")
    check("json pkg.author.name", pkg.author.name == "Anthony")
    check("json pkg.author.email", pkg.author.email == "anthony@zorya.dev")
    check("json pkg.deps.nxh", pkg.dependencies.nxh == "^1.0")
    check("json pkg.scripts.build", pkg.scripts.build == "make")
    check("json pkg.keywords[0]", pkg.keywords[0] == "language")
    check("json pkg.keywords[2]", pkg.keywords[2] == "compiler")

    -- Round-trip
    dec encoded = json.encode(pkg)
    check("json round-trip type", type(encoded) == "string")
    dec decoded = json.decode(encoded)
    check("json round-trip name", decoded.name == "nova")
    check("json round-trip author", decoded.author.name == "Anthony")
end

-- ==========================================================
-- 2. CSV: Employee Database
-- ==========================================================
print("\n=== CSV: Employee Records ===")

do
    dec emp_csv = "id,name,department,salary,active\n1,Alice Smith,Engineering,95000,true\n2,Bob Jones,Marketing,72000,true\n3,Carol White,Engineering,110000,true\n4,Dave Brown,Sales,68000,false\n5,Eve Davis,Engineering,102000,true"

    dec employees = csv.decode(emp_csv)
    check("csv employee count", #employees == 5)
    check("csv emp[0].name", employees[0].name == "Alice Smith")
    check("csv emp[0].department", employees[0].department == "Engineering")
    check("csv emp[0].salary", employees[0].salary == 95000)
    check("csv emp[2].name", employees[2].name == "Carol White")
    check("csv emp[2].salary", employees[2].salary == 110000)
    check("csv emp[3].active", employees[3].active == false)
    check("csv emp[4].name", employees[4].name == "Eve Davis")

    -- Encode back
    dec re_encoded = csv.encode(employees)
    check("csv encode type", type(re_encoded) == "string")
end

-- ==========================================================
-- 3. TSV: Scientific Measurements
-- ==========================================================
print("\n=== TSV: Scientific Data ===")

do
    dec measurements = "timestamp\ttemperature\tpressure\thumidity\n1706745600\t22.5\t1013.25\t45.2\n1706749200\t23.1\t1012.80\t44.8\n1706752800\t24.7\t1012.10\t42.1\n1706756400\t25.3\t1011.50\t40.5"

    dec data_rows = tsv.decode(measurements)
    check("tsv row count", #data_rows == 4)
    check("tsv r0.timestamp", data_rows[0].timestamp == 1706745600)
    check("tsv r0.temperature", type(data_rows[0].temperature) == "number")
    check("tsv r1.pressure", type(data_rows[1].pressure) == "number")
    check("tsv r3.humidity", type(data_rows[3].humidity) == "number")

    -- Encode
    dec tsv_out = tsv.encode(data_rows)
    check("tsv encode type", type(tsv_out) == "string")
end

-- ==========================================================
-- 4. INI: Application Configuration
-- ==========================================================
print("\n=== INI: App Config ===")

do
    dec config_ini = "; Application Configuration\n; Generated by ZORYA Tools\n\n[general]\napp_name = Nova Language\nversion = 0.1.0\ndebug = false\nmax_memory = 256\n\n[compiler]\noptimize = true\nwarn_level = 3\ntarget = native\n\n[paths]\nsource = ./src\nbuild = ./build\ntest = ./tests\n\n[database]\nhost = 127.0.0.1\nport = 5432\nname = nova_dev\npool_size = 10"

    dec cfg = ini.decode(config_ini)
    check("ini general.app_name", cfg.general.app_name == "Nova Language")
    check("ini general.version", cfg.general.version == "0.1.0")
    check("ini general.debug", cfg.general.debug == false)
    check("ini general.max_memory", cfg.general.max_memory == 256)
    check("ini compiler.optimize", cfg.compiler.optimize == true)
    check("ini compiler.warn_level", cfg.compiler.warn_level == 3)
    check("ini compiler.target", cfg.compiler.target == "native")
    check("ini paths.source", cfg.paths.source == "./src")
    check("ini paths.build", cfg.paths.build == "./build")
    check("ini database.host", cfg.database.host == "127.0.0.1")
    check("ini database.port", cfg.database.port == 5432)
    check("ini database.pool_size", cfg.database.pool_size == 10)

    -- Encode
    dec ini_out = ini.encode(cfg)
    check("ini encode type", type(ini_out) == "string")
end

-- ==========================================================
-- 5. TOML: Project Manifest
-- ==========================================================
print("\n=== TOML: Project Manifest ===")

do
    dec manifest = "title = \"Nova Project\"\nversion = \"0.1.0\"\nedition = 2026\n\n[package]\nname = \"nova\"\nlicense = \"MIT\"\nauthors = [\"Anthony Taliento\"]\n\n[build]\noptimize = true\nlto = true\ntarget = \"x86_64-linux\"\n\n[dependencies]\nnxh = \"1.0.0\"\ndagger = \"2.3.1\""

    dec mf = toml.decode(manifest)
    check("toml title", mf.title == "Nova Project")
    check("toml version", mf.version == "0.1.0")
    check("toml edition", mf.edition == 2026)
    check("toml package.name", mf.package.name == "nova")
    check("toml package.license", mf.package.license == "MIT")
    check("toml build.optimize", mf.build.optimize == true)
    check("toml build.lto", mf.build.lto == true)
    check("toml build.target", mf.build.target == "x86_64-linux")
    check("toml deps.nxh", mf.dependencies.nxh == "1.0.0")
    check("toml deps.dagger", mf.dependencies.dagger == "2.3.1")

    -- Encode
    dec toml_out = toml.encode(mf)
    check("toml encode type", type(toml_out) == "string")
end

-- ==========================================================
-- 6. YAML: Docker Compose-style Config
-- ==========================================================
print("\n=== YAML: Docker Compose ===")

do
    dec compose = "version: 3.8\nservices:\n  web:\n    image: nginx\n    port: 80\n  api:\n    image: nova-api\n    port: 3000\n  db:\n    image: postgres\n    port: 5432\n"

    dec dc = yaml.decode(compose)
    check("yaml compose.version", dc.version == 3.8)
    check("yaml services type", type(dc.services) == "table")
    check("yaml web.image", dc.services.web.image == "nginx")
    check("yaml web.port", dc.services.web.port == 80)
    check("yaml api.image", dc.services.api.image == "nova-api")
    check("yaml api.port", dc.services.api.port == 3000)
    check("yaml db.image", dc.services.db.image == "postgres")
    check("yaml db.port", dc.services.db.port == 5432)
end

do
    -- YAML: List of structured records
    dec team = "- name: Alice\n  role: Lead\n  skills:\n    - Nova\n    - C\n- name: Bob\n  role: Developer\n  skills:\n    - TypeScript\n    - Rust\n"

    dec t = yaml.decode(team)
    check("yaml team[0].name", t[0].name == "Alice")
    check("yaml team[0].role", t[0].role == "Lead")
    check("yaml team[1].name", t[1].name == "Bob")
    check("yaml team[1].role", t[1].role == "Developer")
end

do
    -- YAML: Nested maps with booleans
    dec settings = "editor:\n  font_size: 14\n  tab_size: 4\n  word_wrap: true\nlanguage:\n  name: Nova\n  version: 1\n  compiled: true\n"

    dec s = yaml.decode(settings)
    check("yaml editor.font_size", s.editor.font_size == 14)
    check("yaml editor.tab_size", s.editor.tab_size == 4)
    check("yaml editor.word_wrap", s.editor.word_wrap == true)
    check("yaml language.name", s.language.name == "Nova")
    check("yaml language.compiled", s.language.compiled == true)

    -- Encode back
    dec yaml_out = yaml.encode(s)
    check("yaml encode type", type(yaml_out) == "string")
end

-- ==========================================================
-- 7. HTML: Simple Document
-- ==========================================================
print("\n=== HTML: Document ===")

do
    dec doc = '<div class="container"><h1>Nova Language</h1><p>A fast, compiled scripting language.</p><ul><li>Fast VM</li><li>Zero-copy parsing</li></ul></div>'

    dec tree = html.decode(doc)
    check("html root tag", tree.tag == "document")
    dec div = tree.children[0]
    check("html div tag", div.tag == "div")
    check("html div class", div.attrs.class == "container")
    check("html has children", type(div.children) == "table")
end

-- ==========================================================
-- 8. Cross-Format Conversion Pipeline
-- ==========================================================
print("\n=== Cross-Format Pipeline ===")

do
    -- Start with CSV data
    dec src_csv = "name,age,city\nAlice,30,New York\nBob,25,London\nCarol,35,Tokyo"
    dec records = csv.decode(src_csv)
    check("pipeline csv decode", #records == 3)

    -- Convert to JSON
    dec json_str = json.encode(records)
    check("pipeline csv->json", type(json_str) == "string")

    -- Re-decode from JSON
    dec from_json = json.decode(json_str)
    check("pipeline json round-trip", from_json[0].name == "Alice")
end

-- ==========================================================
-- 9. Edge Cases
-- ==========================================================
print("\n=== Edge Cases ===")

do
    -- Empty structures
    dec empty_json = json.decode("{}")
    check("edge empty json", type(empty_json) == "table")

    -- Single record CSV
    dec single_csv = csv.decode("name\nAlice")
    check("edge single csv", single_csv[0].name == "Alice")

    -- INI with only global keys
    dec global_ini = ini.decode("key1 = value1\nkey2 = value2\n")
    check("edge global ini", global_ini.key1 == "value1")

    -- YAML empty value
    dec yaml_nil = yaml.decode("key: null\n")
    check("edge yaml null", yaml_nil.key == nil)

    -- TOML bare keys
    dec toml_bare = toml.decode("name = \"test\"\ncount = 42\n")
    check("edge toml bare", toml_bare.name == "test")
    check("edge toml int", toml_bare.count == 42)

    -- data.detect on various formats
    check("detect csv", data.detect("a,b,c\n1,2,3\n") == "csv")
    check("detect tsv", data.detect("a\tb\tc\n1\t2\t3\n") == "tsv")
    check("detect toml", data.detect("key = value\n") == "toml")
    check("detect yaml", data.detect("key: value\nfoo: bar\n") == "yaml")
end

-- ==========================================================
-- 10. Format-Specific Features
-- ==========================================================
print("\n=== Format Features ===")

do
    -- CSV with quoted fields containing commas
    dec quoted = csv.decode('name,bio\nAlice,"PhD, MIT"\nBob,"MSc, Stanford"')
    check("csv quoted comma", quoted[0].bio == "PhD, MIT")
    check("csv quoted comma 2", quoted[1].bio == "MSc, Stanford")
end

do
    -- INI with multiple sections and typed values
    dec multi_ini = ini.decode("[server]\nhost = 0.0.0.0\nport = 443\nssl = true\n\n[logging]\nlevel = debug\nverbose = false\nmax_size = 1048576\n")
    check("ini multi server.ssl", multi_ini.server.ssl == true)
    check("ini multi logging.level", multi_ini.logging.level == "debug")
    check("ini multi logging.verbose", multi_ini.logging.verbose == false)
    check("ini multi logging.max_size", multi_ini.logging.max_size == 1048576)
end

do
    -- TOML with arrays
    dec toml_arr = toml.decode("colors = [\"red\", \"green\", \"blue\"]\nnums = [1, 2, 3]\n")
    check("toml array type", type(toml_arr.colors) == "table")
    check("toml array[0]", toml_arr.colors[0] == "red")
    check("toml array[2]", toml_arr.colors[2] == "blue")
    check("toml num array[1]", toml_arr.nums[1] == 2)
end

do
    -- YAML with inline comments
    dec yaml_comments = yaml.decode("name: Nova  # Language name\nversion: 1  # Major version\n")
    check("yaml inline comment", yaml_comments.name == "Nova")
    check("yaml inline comment 2", yaml_comments.version == 1)
end

-- ==========================================================
-- SUMMARY
-- ==========================================================
print("")
printf("============================================\n")
printf("REAL DATA TESTS: %d passed, %d failed\n", pass, fail)
printf("============================================\n")
if fail > 0 then
    error("SOME TESTS FAILED")
end
