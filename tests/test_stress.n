-- ==========================================================
-- test_stress.n - VM Hardening & Stress Test Suite
--
-- Pushes the Nova VM to its limits across:
--   1. Deep recursion & call stack
--   2. Complex if/elseif chains
--   3. Large tables (data analytics scale)
--   4. Control flow (loops, break, continue, nested)
--   5. Closure / upvalue pressure
--   6. String interning under load
--   7. GC stability under allocation pressure
--   8. Edge cases & error recovery
--
-- Every section uses do..end blocks to scope locals.
--
-- Copyright (c) 2026 Zorya Corporation
-- ==========================================================

dec pass = 0
dec fail = 0
dec total_start = os.clock()

dec function check(name, cond)
    if cond then
        pass = pass + 1
        printf("  PASS: %s\n", name)
    else
        fail = fail + 1
        printf("  FAIL: %s\n", name)
    end
end

dec function section(name)
    printf("\n=== %s ===\n", name)
end

-- ==========================================================
section("1. DEEP RECURSION & CALL DEPTH")
-- ==========================================================

do
    -- Basic recursion to depth 190 (limit is 200, minus overhead)
    dec function recurse(n)
        if n <= 0 then return 0 end
        return 1 + recurse(n - 1)
    end

    dec ok, result = pcall(recurse, 190)
    check("recurse 190 deep", ok and result == 190)
end

do
    -- Hit the call depth limit gracefully
    dec function bomb(n)
        return bomb(n + 1)
    end

    dec ok, err = pcall(bomb, 0)
    check("stack overflow caught", not ok)
    check("overflow msg", type(err) == "string")
end

do
    -- Mutual recursion (A calls B calls A)
    dec function is_even(n)
        if n == 0 then return true end
        return is_odd(n - 1)
    end
    function is_odd(n)
        if n == 0 then return false end
        return is_even(n - 1)
    end

    check("mutual recursion 100", is_even(100) == true)
    check("mutual recursion 99", is_even(99) == false)
end

do
    -- Fibonacci with deep recursion but memoized
    dec cache = {}
    dec function fib(n)
        if n <= 1 then return n end
        if cache[n] then return cache[n] end
        dec r = fib(n - 1) + fib(n - 2)
        cache[n] = r
        return r
    end

    check("fib(30) memoized", fib(30) == 832040)
    check("fib(50) memoized", fib(50) == 12586269025)
end

do
    -- Tail-call-like pattern (iterative recursion via loop)
    dec function sum_iter(n, acc)
        if n <= 0 then return acc end
        -- Can't use tail call, so iterate
        while n > 0 do
            acc = acc + n
            n = n - 1
        end
        return acc
    end

    check("sum 10000 iter", sum_iter(10000, 0) == 50005000)
end

-- ==========================================================
section("2. COMPLEX IF/ELSEIF CHAINS")
-- ==========================================================

do
    -- 20-branch elseif chain (simulates state machine)
    dec function classify(n)
        if n == 0 then return "zero"
        elseif n == 1 then return "one"
        elseif n == 2 then return "two"
        elseif n == 3 then return "three"
        elseif n == 4 then return "four"
        elseif n == 5 then return "five"
        elseif n == 6 then return "six"
        elseif n == 7 then return "seven"
        elseif n == 8 then return "eight"
        elseif n == 9 then return "nine"
        elseif n == 10 then return "ten"
        elseif n == 11 then return "eleven"
        elseif n == 12 then return "twelve"
        elseif n == 13 then return "thirteen"
        elseif n == 14 then return "fourteen"
        elseif n == 15 then return "fifteen"
        elseif n == 16 then return "sixteen"
        elseif n == 17 then return "seventeen"
        elseif n == 18 then return "eighteen"
        elseif n == 19 then return "nineteen"
        else return "big"
        end
    end

    check("elseif chain first", classify(0) == "zero")
    check("elseif chain mid", classify(10) == "ten")
    check("elseif chain last", classify(19) == "nineteen")
    check("elseif chain default", classify(100) == "big")
end

do
    -- Nested if chains (conditional matrix)
    dec function quadrant(x, y)
        if x > 0 then
            if y > 0 then return "I"
            elseif y < 0 then return "IV"
            else return "+X"
            end
        elseif x < 0 then
            if y > 0 then return "II"
            elseif y < 0 then return "III"
            else return "-X"
            end
        else
            if y > 0 then return "+Y"
            elseif y < 0 then return "-Y"
            else return "origin"
            end
        end
    end

    check("quadrant I", quadrant(1, 1) == "I")
    check("quadrant III", quadrant(-1, -1) == "III")
    check("quadrant origin", quadrant(0, 0) == "origin")
    check("quadrant +X", quadrant(5, 0) == "+X")
end

do
    -- Elseif chain in hot loop (10K iterations)
    dec counts = {a = 0, b = 0, c = 0, d = 0}
    for i = 0, 9999 do
        dec m = i % 4
        if m == 0 then counts.a = counts.a + 1
        elseif m == 1 then counts.b = counts.b + 1
        elseif m == 2 then counts.c = counts.c + 1
        else counts.d = counts.d + 1
        end
    end
    check("elseif hot loop", counts.a == 2500 and counts.b == 2500)
end

do
    -- Compound boolean conditions
    dec function access_level(role, verified, age)
        if role == "admin" and verified then
            return "full"
        elseif role == "mod" and verified and age >= 18 then
            return "moderate"
        elseif role == "user" and verified then
            return "basic"
        elseif role == "user" and not verified then
            return "limited"
        elseif role == "guest" then
            return "readonly"
        else
            return "denied"
        end
    end

    check("access admin", access_level("admin", true, 30) == "full")
    check("access mod", access_level("mod", true, 25) == "moderate")
    check("access unverified", access_level("user", false, 20) == "limited")
    check("access guest", access_level("guest", false, 0) == "readonly")
    check("access denied", access_level("bot", true, 0) == "denied")
end

-- ==========================================================
section("3. LARGE TABLES (Data Analytics Scale)")
-- ==========================================================

do
    -- Build a 10,000-row dataset with 5 columns
    dec dataset = {}
    dec start = os.clock()
    for i = 0, 9999 do
        dataset[i] = {
            id = i,
            name = sprintf("user_%04d", i),
            score = (i * 7 + 13) % 100,
            active = (i % 3 != 0),
            region = (i % 5 == 0) and "east" or
                     (i % 5 == 1) and "west" or
                     (i % 5 == 2) and "north" or
                     (i % 5 == 3) and "south" or "central"
        }
    end
    dec build_time = os.clock() - start

    check("dataset 10K rows", #dataset == 10000)
    check("dataset build < 1s", build_time < 1.0)
    printf("  INFO: 10K rows built in %.3f sec\n", build_time)
end

do
    -- Aggregation: count active users per region
    dec dataset = {}
    for i = 0, 9999 do
        dataset[i] = {
            active = (i % 3 != 0),
            region = (i % 5 == 0) and "east" or
                     (i % 5 == 1) and "west" or
                     (i % 5 == 2) and "north" or
                     (i % 5 == 3) and "south" or "central"
        }
    end

    dec agg = {}
    dec start = os.clock()
    for i = 0, 9999 do
        dec row = dataset[i]
        if row.active then
            dec r = row.region
            if agg[r] == nil then agg[r] = 0 end
            agg[r] = agg[r] + 1
        end
    end
    dec agg_time = os.clock() - start

    -- Verify: 10000 rows, 2/3 active = ~6666, split across 5 regions
    dec total_active = 0
    for k, v in pairs(agg) do
        total_active = total_active + v
    end
    check("aggregation total", total_active == 6666)
    check("aggregation speed", agg_time < 0.5)
    printf("  INFO: aggregation in %.4f sec\n", agg_time)
end

do
    -- Wide table: 200 columns per row
    dec wide = {}
    for i = 0, 999 do
        dec row = {}
        for j = 0, 199 do
            row[sprintf("col_%03d", j)] = i * 200 + j
        end
        wide[i] = row
    end

    -- Verify random access
    check("wide table [0].col_000", wide[0].col_000 == 0)
    check("wide table [500].col_100", wide[500].col_100 == 100100)
    check("wide table [999].col_199", wide[999].col_199 == 199999)
end

do
    -- Hash table stress: 50K unique string keys
    dec big = {}
    dec start = os.clock()
    for i = 0, 49999 do
        big[sprintf("key_%05d", i)] = i
    end
    dec insert_time = os.clock() - start

    -- Verify random lookups
    check("50K insert key_00000", big.key_00000 == 0)
    check("50K insert key_25000", big.key_25000 == 25000)
    check("50K insert key_49999", big.key_49999 == 49999)
    check("50K insert speed", insert_time < 60.0)  -- Known slow: string hashing
    printf("  INFO: 50K string key inserts in %.3f sec\n", insert_time)

    -- Lookup throughput
    start = os.clock()
    dec sum = 0
    for i = 0, 49999 do
        sum = sum + big[sprintf("key_%05d", i)]
    end
    dec lookup_time = os.clock() - start
    check("50K lookups sum", sum == 1249975000)
    printf("  INFO: 50K string lookups in %.3f sec\n", lookup_time)
end

do
    -- Deeply nested table (100 levels)
    dec root = {level = 0}
    dec current = root
    for i = 1, 100 do
        current.child = {level = i}
        current = current.child
    end

    -- Walk to bottom
    current = root
    dec depth = 0
    while current.child do
        depth = depth + 1
        current = current.child
    end
    check("nested 100 levels", depth == 100 and current.level == 100)
end

-- ==========================================================
section("4. CONTROL FLOW")
-- ==========================================================

do
    -- Nested for loops (3 deep)
    dec count = 0
    for i = 0, 49 do
        for j = 0, 49 do
            for k = 0, 3 do
                count = count + 1
            end
        end
    end
    check("triple nested for", count == 10000)
end

do
    -- While with break
    dec n = 0
    dec i = 0
    while true do
        if i >= 1000 then break end
        n = n + i
        i = i + 1
    end
    check("while+break sum", n == 499500)
end

do
    -- Repeat-until loop
    dec n = 0
    dec i = 0
    repeat
        n = n + i
        i = i + 1
    until i >= 100
    check("repeat-until", n == 4950)
end

do
    -- For-in with pairs on large table
    dec t = {}
    for i = 0, 999 do
        t[sprintf("k%d", i)] = i
    end
    dec sum = 0
    dec count = 0
    for k, v in pairs(t) do
        sum = sum + v
        count = count + 1
    end
    check("pairs 1000 entries", count == 1000)
    check("pairs sum", sum == 499500)
end

do
    -- Numeric for with continue (skip evens)
    dec odd_sum = 0
    for i = 0, 99 do
        if i % 2 == 0 then continue end
        odd_sum = odd_sum + i
    end
    check("continue skip evens", odd_sum == 2500)
end

do
    -- Nested break out of inner loop only
    dec outer_count = 0
    dec inner_total = 0
    for i = 0, 9 do
        outer_count = outer_count + 1
        for j = 0, 999 do
            if j >= 5 then break end
            inner_total = inner_total + 1
        end
    end
    check("nested break", outer_count == 10 and inner_total == 50)
end

do
    -- Long sequential control flow (simulates a parser state machine)
    dec function tokenize(input)
        dec tokens = {}
        dec ti = 0
        dec i = 0
        dec len = #input

        while i < len do
            dec ch = string.sub(input, i, i)
            if ch == " " or ch == "\t" then
                i = i + 1
            elseif ch == "+" or ch == "-" or ch == "*" or ch == "/" then
                tokens[ti] = {type = "op", val = ch}
                ti = ti + 1
                i = i + 1
            elseif ch >= "0" and ch <= "9" then
                dec start = i
                while i < len do
                    dec d = string.sub(input, i, i)
                    if d < "0" or d > "9" then break end
                    i = i + 1
                end
                tokens[ti] = {type = "num", val = string.sub(input, start, i - 1)}
                ti = ti + 1
            elseif ch >= "a" and ch <= "z" then
                dec start = i
                while i < len do
                    dec d = string.sub(input, i, i)
                    if d < "a" or d > "z" then break end
                    i = i + 1
                end
                tokens[ti] = {type = "id", val = string.sub(input, start, i - 1)}
                ti = ti + 1
            else
                tokens[ti] = {type = "unknown", val = ch}
                ti = ti + 1
                i = i + 1
            end
        end
        return tokens, ti
    end

    dec toks, count = tokenize("x + 123 * y - 42 / z")
    check("tokenizer count", count == 9)
    check("tokenizer first", toks[0].type == "id" and toks[0].val == "x")
    check("tokenizer num", toks[2].type == "num" and toks[2].val == "123")
    check("tokenizer last", toks[8].type == "id" and toks[8].val == "z")
end

-- ==========================================================
section("5. CLOSURE & UPVALUE PRESSURE")
-- ==========================================================

do
    -- Create 100 closures each capturing a unique upvalue
    dec closures = {}
    for i = 0, 99 do
        dec val = i * 10
        closures[i] = function() return val end
    end

    check("closure[0]", closures[0]() == 0)
    check("closure[50]", closures[50]() == 500)
    check("closure[99]", closures[99]() == 990)
end

do
    -- Closures that mutate shared upvalue
    dec counter = 0
    dec function make_ops()
        dec function inc() counter = counter + 1 end
        dec function decr() counter = counter - 1 end
        dec function get() return counter end
        return inc, decr, get
    end

    dec inc, decr, get = make_ops()
    for i = 0, 999 do inc() end
    for i = 0, 499 do decr() end
    check("shared upvalue", get() == 500)
end

do
    -- Nested closure depth (closure returning closure returning closure...)
    dec function make_adder(a)
        return function(b)
            return function(c)
                return function(d)
                    return a + b + c + d
                end
            end
        end
    end

    check("nested closures", make_adder(1)(2)(3)(4) == 10)
end

do
    -- Closure over loop variable (common bug pattern)
    dec fns = {}
    for i = 0, 9 do
        dec captured = i
        fns[i] = function() return captured end
    end
    -- Each closure should capture its own i
    check("loop closure[0]", fns[0]() == 0)
    check("loop closure[5]", fns[5]() == 5)
    check("loop closure[9]", fns[9]() == 9)
end

-- ==========================================================
section("6. STRING OPERATIONS UNDER LOAD")
-- ==========================================================

do
    -- Build a large string via concatenation (tests GC pressure)
    dec parts = {}
    for i = 0, 999 do
        parts[i] = sprintf("line %d: data\n", i)
    end
    dec big = table.concat(parts)
    check("concat 1000 parts", #big > 10000)
    check("concat starts with", string.sub(big, 0, 5) == "line 0")
end

do
    -- String interning: create many unique short strings, verify equality
    dec t = {}
    for i = 0, 4999 do
        dec key = sprintf("s%d", i)
        t[key] = true
    end
    -- Re-create and verify interned match
    dec found = 0
    for i = 0, 4999 do
        dec key = sprintf("s%d", i)
        if t[key] then found = found + 1 end
    end
    check("string intern 5K", found == 5000)
end

do
    -- String format heavy (tests sprintf throughput)
    dec start = os.clock()
    for i = 0, 9999 do
        dec s = sprintf("record_%d_value_%d_status_%s", i, i * 2, "active")
    end
    dec elapsed = os.clock() - start
    check("10K sprintf", elapsed < 1.0)
    printf("  INFO: 10K sprintf in %.4f sec\n", elapsed)
end

-- ==========================================================
section("7. GC STABILITY UNDER PRESSURE")
-- ==========================================================

do
    -- Rapid allocation/deallocation cycle
    dec mem_before = collectgarbage("count")
    for i = 0, 9999 do
        dec t = {a = 1, b = 2, c = 3}
        dec s = sprintf("temp_%d", i)
    end
    collectgarbage("collect")
    dec mem_after = collectgarbage("count")
    -- Memory should not grow unbounded (GC should reclaim)
    check("GC reclaims temps", mem_after < mem_before * 3)
    printf("  INFO: before=%.1fKB after=%.1fKB\n", mem_before, mem_after)
end

do
    -- Closure + table allocation mix
    dec fns = {}
    for i = 0, 4999 do
        dec data = {x = i, y = i * 2}
        fns[i] = function() return data.x + data.y end
    end
    -- Call all closures
    dec sum = 0
    for i = 0, 4999 do
        sum = sum + fns[i]()
    end
    check("5K closure+table", sum == 37492500)
end

do
    -- GC during nested calls
    dec function alloc_deep(n)
        if n <= 0 then return {} end
        dec t = {val = n, sub = alloc_deep(n - 1)}
        if n % 20 == 0 then collectgarbage("step") end
        return t
    end

    dec tree = alloc_deep(150)
    -- Walk to verify
    dec depth = 0
    dec cur = tree
    while cur.sub do
        depth = depth + 1
        cur = cur.sub
    end
    check("GC during recursion", depth == 150)
end

-- ==========================================================
section("8. ERROR RECOVERY & EDGE CASES")
-- ==========================================================

do
    -- pcall catches runtime errors
    dec ok, err = pcall(function()
        dec t = nil
        return t.field
    end)
    check("pcall catches nil index", not ok)
end

do
    -- Nested pcall
    dec ok1, result1 = pcall(function()
        dec ok2, result2 = pcall(function()
            error("inner")
        end)
        return ok2, result2
    end)
    check("nested pcall outer ok", ok1 == true)
    check("nested pcall inner caught", result1 == false)
end

do
    -- xpcall with handler
    dec handled = false
    dec ok, result = xpcall(function()
        error("test error")
    end, function(err)
        handled = true
        return "handled: " .. err
    end)
    check("xpcall handler called", handled)
    check("xpcall result", not ok)
end

do
    -- Error in loop doesn't corrupt state
    dec sum = 0
    for i = 0, 9 do
        dec ok, val = pcall(function()
            if i == 5 then error("skip") end
            return i
        end)
        if ok then sum = sum + val end
    end
    check("pcall in loop", sum == 40) -- 0+1+2+3+4+6+7+8+9 = 40
end

do
    -- Type coercion edge cases
    check("tonumber int", tonumber("42") == 42)
    check("tonumber float", tonumber("3.14") == 3.14)
    check("tonumber nil", tonumber("abc") == nil)
    check("tostring int", tostring(42) == "42")
    check("tostring nil", tostring(nil) == "nil")
    check("tostring bool", tostring(true) == "true")
end

do
    -- Table with mixed key types
    dec mixed = {}
    mixed[0] = "zero"
    mixed[1] = "one"
    mixed["name"] = "test"
    -- Note: boolean/float keys not supported in Nova tables

    check("mixed int key", mixed[0] == "zero")
    check("mixed str key", mixed.name == "test")
end

-- ==========================================================
section("9. METATABLE CHAINS UNDER LOAD")
-- ==========================================================

do
    -- Build a prototype chain 10 levels deep
    dec function make_proto(level, parent)
        dec proto = {}
        proto[sprintf("level_%d", level)] = level
        if parent then
            setmetatable(proto, {__index = parent})
        end
        return proto
    end

    dec chain = make_proto(0, nil)
    for i = 1, 10 do
        chain = make_proto(i, chain)
    end

    check("meta chain top", chain.level_10 == 10)
    check("meta chain mid", chain.level_5 == 5)
    check("meta chain bottom", chain.level_0 == 0)
end

do
    -- __index function lookup (called many times)
    dec backing = {}
    for i = 0, 999 do
        backing[sprintf("field_%d", i)] = i
    end

    dec proxy = setmetatable({}, {
        __index = function(self, key)
            return backing[key]
        end
    })

    dec sum = 0
    for i = 0, 999 do
        sum = sum + proxy[sprintf("field_%d", i)]
    end
    check("__index 1K lookups", sum == 499500)
end

-- ==========================================================
section("10. PERFORMANCE BENCHMARKS")
-- ==========================================================

do
    -- Sieve of Eratosthenes to 10000
    dec start = os.clock()
    dec SIZE = 10000
    dec is_prime = {}
    for i = 0, SIZE do is_prime[i] = true end
    is_prime[0] = false
    is_prime[1] = false

    dec i = 2
    while i * i <= SIZE do
        if is_prime[i] then
            dec j = i * i
            while j <= SIZE do
                is_prime[j] = false
                j = j + i
            end
        end
        i = i + 1
    end

    dec count = 0
    for k = 0, SIZE do
        if is_prime[k] then count = count + 1 end
    end
    dec elapsed = os.clock() - start
    check("sieve 10K primes", count == 1229)
    printf("  INFO: sieve in %.4f sec\n", elapsed)
end

do
    -- Matrix multiply 50x50
    dec N = 50
    dec A = {}
    dec B = {}
    for i = 0, N - 1 do
        A[i] = {}
        B[i] = {}
        for j = 0, N - 1 do
            A[i][j] = (i + j) % 7
            B[i][j] = (i * j + 1) % 5
        end
    end

    dec start = os.clock()
    dec C = {}
    for i = 0, N - 1 do
        C[i] = {}
        for j = 0, N - 1 do
            dec sum = 0
            for k = 0, N - 1 do
                sum = sum + A[i][k] * B[k][j]
            end
            C[i][j] = sum
        end
    end
    dec elapsed = os.clock() - start

    check("matrix 50x50 done", type(C[0][0]) == "integer" or type(C[0][0]) == "number")
    check("matrix speed", elapsed < 1.0)
    printf("  INFO: 50x50 matmul in %.4f sec\n", elapsed)
end

do
    -- Function call throughput
    dec c = 0
    dec function inc() c = c + 1 end

    dec start = os.clock()
    for i = 0, 499999 do
        inc()
    end
    dec elapsed = os.clock() - start
    check("500K func calls", c == 500000)
    printf("  INFO: 500K calls in %.4f sec (%.1fM calls/sec)\n",
           elapsed, 0.5 / elapsed)
end

do
    -- Table insert/remove throughput
    dec t = {}
    dec start = os.clock()
    for i = 0, 9999 do
        table.insert(t, i)
    end
    for i = 0, 4999 do
        table.remove(t)
    end
    dec elapsed = os.clock() - start
    check("insert/remove 15K ops", #t == 5000)
    printf("  INFO: 15K insert/remove in %.4f sec\n", elapsed)
end

-- ==========================================================
-- SUMMARY
-- ==========================================================
dec total_elapsed = os.clock() - total_start
print("")
printf("============================================\n")
printf("STRESS TESTS: %d passed, %d failed\n", pass, fail)
printf("Total time: %.3f seconds\n", total_elapsed)
printf("============================================\n")
if fail > 0 then
    error("SOME STRESS TESTS FAILED")
end
