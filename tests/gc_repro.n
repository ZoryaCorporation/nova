-- gc_repro.n: Minimal reproducer for GC corruption
-- Phase 1: Generate sustained allocation pressure (like bench sections 1-11)
-- Phase 2: Build graph with adjacency lists (triggers corruption)

echo("Phase 1: sustained allocation pressure...")
dec count = 0
for i = 0, 50000 do
    dec a = i + 1
    dec b = i + 2
    dec t = {i, a, b}
    dec s = "key_" .. tostring(i)
    count = count + 1
end
echo("  allocated", count, "objects")

echo("Phase 2: more pressure with retained tables...")
dec retained = {}
for i = 0, 5000 do
    dec obj = {}
    obj.x = i
    obj.y = i * 2
    obj.name = "item_" .. tostring(i)
    retained[i] = obj
end
echo("  retained", 5000, "objects")

echo("Phase 3: building graph adjacency lists...")
dec graph = {}
dec N = 50
for i = 0, N - 1 do
    graph[i] = {}
end

-- Populated in separate loop (matches bench_algorithms pattern)
for i = 0, N - 2 do
    dec neighbors = graph[i]
    dec edge1 = i + 1
    dec edge2 = (i + 7) % N
    neighbors[#neighbors] = edge1
    neighbors[#neighbors] = edge2
end
echo("  graph built with", N, "nodes")

-- Verify graph values BEFORE BFS
echo("Phase 3b: verifying graph integrity...")
dec ok = true
for i = 0, N - 2 do
    dec neighbors = graph[i]
    if not neighbors then
        echo("  ERROR: graph[" .. tostring(i) .. "] is nil!")
        ok = false
    else
        dec v0 = neighbors[0]
        dec v1 = neighbors[1]
        dec t0 = type(v0)
        dec t1 = type(v1)
        if t0 != "integer" and t0 != "number" then
            echo("  ERROR: graph[" .. tostring(i) .. "][0] type=" .. t0 .. " val=" .. tostring(v0))
            ok = false
        end
        if t1 != "integer" and t1 != "number" then
            echo("  ERROR: graph[" .. tostring(i) .. "][1] type=" .. t1 .. " val=" .. tostring(v1))
            ok = false
        end
    end
end
if ok then
    echo("  graph integrity OK")
else
    echo("  graph integrity FAILED -- stopping")
    error("graph corrupted before BFS")
end

echo("Phase 4: BFS traversal...")
dec visited = {}
dec queue = {}
queue[0] = 0
dec qhead = 0
dec qtail = 0
visited[0] = true

while qhead <= qtail do
    dec node = queue[qhead]
    qhead = qhead + 1

    dec neighbors = graph[node]
    if neighbors then
        dec nlen = #neighbors
        for k = 0, nlen - 1 do
            dec nb = neighbors[k]
            dec nbtype = type(nb)
            if nbtype != "integer" and nbtype != "number" then
                echo("  CORRUPTION at BFS: neighbors[" .. tostring(k) .. "] type=" .. nbtype .. " val=" .. tostring(nb) .. " (node=" .. tostring(node) .. ")")
                echo("  ABORTING BFS")
                goto bfs_done
            end
            if nb and not visited[nb] then
                visited[nb] = true
                qtail = qtail + 1
                queue[qtail] = nb
            end
        end
    end
end
::bfs_done::
echo("  BFS complete")

echo("Phase 5: for-loop after pressure (DP test)...")
dec dp = {}
dec M = 30
for i = 0, M do
    dp[i] = {}
    for j = 0, M do
        if i == 0 or j == 0 then
            dp[i][j] = 0
        else
            dec a = dp[i-1][j]
            dec b = dp[i][j-1]
            if a > b then
                dp[i][j] = a + 1
            else
                dp[i][j] = b + 1
            end
        end
    end
end
echo("  DP table filled:", M, "x", M)

echo("ALL PHASES PASSED")
