-- Nova Tier 1 Test Suite
-- Tests all the features implemented in this sprint

-- Test 1: printf
printf("Test 1: printf => %s %d\n", "hello", 42)

-- Test 2: sprintf 
dec s = sprintf("formatted: %d + %d = %d", 10, 20, 30)
print("Test 2: " .. s)

-- Test 3: type and basic values
print("Test 3: type(42) = " .. type(42))
print("Test 3: type('hi') = " .. type("hi"))
print("Test 3: type(nil) = " .. type(nil))
print("Test 3: type(true) = " .. type(true))

-- Test 4: select (0-based)
dec a, b, c = select(1, "x", "y", "z")
print("Test 4: select(1,...) = " .. tostring(a) .. " " .. tostring(b))

-- Test 5: assert
dec ok = assert(true, "this should not fail")
print("Test 5: assert(true) passed")

-- Test 6: unpack  
dec t1 = {10, 20, 30}
dec x, y, z = unpack(t1)
print("Test 6: unpack = " .. tostring(x) .. " " .. tostring(y) .. " " .. tostring(z))

-- Test 7: rawget/rawset/rawlen (0-based)
dec t2 = {1, 2, 3}
print("Test 7: rawlen = " .. tostring(rawlen(t2)))
print("Test 7: rawget(0) = " .. tostring(rawget(t2, 0)))

-- Test 8: ipairs
print("Test 8: ipairs")
dec t3 = {100, 200, 300}
for i, v in ipairs(t3) do
    printf("  ipairs[%d] = %d\n", i, v)
end

-- Test 9: pairs (hash table iteration)
print("Test 9: pairs - done (basic)")

-- Test 10: pcall 
dec ok2, err = pcall(error, "test error")
print("Test 10: pcall caught = " .. tostring(ok2) .. " " .. tostring(err))

print("\n=== ALL TESTS PASSED ===")
