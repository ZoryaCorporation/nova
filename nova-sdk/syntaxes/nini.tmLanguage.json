{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "name": "NINI",
    "scopeName": "source.nini",
    "fileTypes": ["nini", "ni"],
    "patterns": [
        { "include": "#comments" },
        { "include": "#task-section" },
        { "include": "#section" },
        { "include": "#include-directive" },
        { "include": "#array-push" },
        { "include": "#key-value" }
    ],
    "repository": {

        "comments": {
            "patterns": [
                {
                    "comment": "Line comment starting with #",
                    "name": "comment.line.number-sign.nini",
                    "match": "^\\s*#(?!\\w).*$"
                },
                {
                    "comment": "Inline comment # (after value)",
                    "name": "comment.line.inline.nini",
                    "match": "(?<=\\S)\\s+(#.*)$",
                    "captures": {
                        "1": { "name": "comment.line.inline.nini" }
                    }
                },
                {
                    "comment": "Line comment starting with ;",
                    "name": "comment.line.semicolon.nini",
                    "match": "^\\s*;.*$"
                },
                {
                    "comment": "Inline comment ; (after value)",
                    "name": "comment.line.inline.nini",
                    "match": "(?<=\\S)\\s+(;.*)$",
                    "captures": {
                        "1": { "name": "comment.line.inline.nini" }
                    }
                }
            ]
        },

        "task-section": {
            "patterns": [
                {
                    "comment": "[task:name] — NINI task definition section",
                    "match": "^\\s*\\[(task):([a-zA-Z_][a-zA-Z0-9_-]*)\\]",
                    "captures": {
                        "1": { "name": "keyword.control.task.nini" },
                        "2": { "name": "entity.name.function.task.nini" }
                    }
                }
            ]
        },

        "section": {
            "patterns": [
                {
                    "comment": "[section] or [section.subsection] — NINI section header",
                    "match": "^\\s*\\[([^\\]]+)\\]",
                    "captures": {
                        "1": { "name": "entity.name.section.nini" }
                    }
                }
            ]
        },

        "include-directive": {
            "patterns": [
                {
                    "comment": "@include file — NINI file inclusion",
                    "match": "^\\s*(@include)\\s+(.+)",
                    "captures": {
                        "1": { "name": "keyword.control.directive.include.nini" },
                        "2": { "name": "string.unquoted.path.nini" }
                    }
                }
            ]
        },

        "array-push": {
            "patterns": [
                {
                    "comment": "key[] = value — NINI array push syntax",
                    "match": "^\\s*([a-zA-Z_][a-zA-Z0-9_.\\-]*)\\[\\]\\s*(=)\\s*(.*)",
                    "captures": {
                        "1": { "name": "variable.other.key.nini" },
                        "2": { "name": "keyword.operator.assignment.nini" },
                        "3": {
                            "patterns": [
                                { "include": "#value" }
                            ]
                        }
                    }
                }
            ]
        },

        "key-value": {
            "patterns": [
                {
                    "comment": "key = value — NINI key-value pair",
                    "match": "^\\s*([a-zA-Z_][a-zA-Z0-9_.\\-]*)\\s*(=)\\s*(.*)",
                    "captures": {
                        "1": { "name": "variable.other.key.nini" },
                        "2": { "name": "keyword.operator.assignment.nini" },
                        "3": {
                            "patterns": [
                                { "include": "#value" }
                            ]
                        }
                    }
                }
            ]
        },

        "value": {
            "patterns": [
                {
                    "comment": "Multi-line string \"\"\"...\"\"\"",
                    "name": "string.quoted.triple.nini",
                    "begin": "\"\"\"",
                    "end": "^\"\"\""
                },
                {
                    "comment": "Inline array [a, b, c]",
                    "name": "meta.array.nini",
                    "begin": "\\[",
                    "end": "\\]",
                    "beginCaptures": {
                        "0": { "name": "punctuation.definition.array.begin.nini" }
                    },
                    "endCaptures": {
                        "0": { "name": "punctuation.definition.array.end.nini" }
                    },
                    "patterns": [
                        { "include": "#typed-values" },
                        {
                            "name": "punctuation.separator.comma.nini",
                            "match": ","
                        },
                        {
                            "comment": "Unquoted array item (string)",
                            "name": "string.unquoted.nini",
                            "match": "[^,\\]\\s]+"
                        }
                    ]
                },
                { "include": "#interpolation" },
                { "include": "#typed-values" },
                {
                    "comment": "Unquoted string value (fallback)",
                    "name": "string.unquoted.nini",
                    "match": "[^#;]+"
                }
            ]
        },

        "typed-values": {
            "patterns": [
                {
                    "comment": "Quoted string",
                    "name": "string.quoted.double.nini",
                    "begin": "\"",
                    "end": "\""
                },
                {
                    "comment": "Boolean true values",
                    "name": "constant.language.boolean.true.nini",
                    "match": "\\b(true|yes|on)\\b"
                },
                {
                    "comment": "Boolean false values",
                    "name": "constant.language.boolean.false.nini",
                    "match": "\\b(false|no|off)\\b"
                },
                {
                    "comment": "Nil/null values",
                    "name": "constant.language.null.nini",
                    "match": "\\b(nil|null|none)\\b"
                },
                {
                    "comment": "Float number",
                    "name": "constant.numeric.float.nini",
                    "match": "-?\\d+\\.\\d+"
                },
                {
                    "comment": "Integer number",
                    "name": "constant.numeric.integer.nini",
                    "match": "-?\\d+"
                }
            ]
        },

        "interpolation": {
            "patterns": [
                {
                    "comment": "${section.key} variable interpolation",
                    "match": "(\\$\\{)([^}]+)(\\})",
                    "captures": {
                        "1": { "name": "punctuation.section.interpolation.begin.nini" },
                        "2": { "name": "variable.other.interpolation.nini" },
                        "3": { "name": "punctuation.section.interpolation.end.nini" }
                    }
                }
            ]
        }
    }
}
