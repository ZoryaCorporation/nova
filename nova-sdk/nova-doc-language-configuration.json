{
    "comments": {
        "lineComment": "#"
    },
    "brackets": [
        ["{", "}"],
        ["[", "]"],
        ["(", ")"],
        ["<<", ">>"]
    ],
    "autoClosingPairs": [
        { "open": "{", "close": "}" },
        { "open": "[", "close": "]" },
        { "open": "(", "close": ")" },
        { "open": "\"", "close": "\"", "notIn": ["string", "comment"] },
        { "open": "<<", "close": ">>", "notIn": ["comment"] },
        { "open": "${", "close": "}", "notIn": ["comment"] }
    ],
    "surroundingPairs": [
        { "open": "\"", "close": "\"" },
        { "open": "[", "close": "]" },
        { "open": "(", "close": ")" },
        { "open": "<<", "close": ">>" }
    ],
    "folding": {
        "markers": {
            "start": "^\\s*\\[|^<<",
            "end": "(?=^\\s*\\[|\\z)|^>>"
        }
    },
    "wordPattern": "[a-zA-Z_@+!][a-zA-Z0-9_.\\-]*",
    "onEnterRules": [
        {
            "beforeText": "^\\s*\\[x\\]",
            "action": {
                "indent": "none",
                "appendText": "[x] "
            }
        },
        {
            "beforeText": "^\\s*\\[ \\]",
            "action": {
                "indent": "none",
                "appendText": "[ ] "
            }
        }
    ]
}
