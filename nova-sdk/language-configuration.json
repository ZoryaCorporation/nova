{
    "comments": {
        "lineComment": "--",
        "blockComment": ["--[[", "]]"]
    },
    "brackets": [
        ["{", "}"],
        ["[", "]"],
        ["(", ")"]
    ],
    "autoClosingPairs": [
        { "open": "{", "close": "}" },
        { "open": "[", "close": "]" },
        { "open": "(", "close": ")" },
        { "open": "\"", "close": "\"", "notIn": ["string", "comment"] },
        { "open": "'", "close": "'", "notIn": ["string", "comment"] },
        { "open": "`", "close": "`", "notIn": ["string", "comment"] },
        { "open": "[[", "close": "]]", "notIn": ["string", "comment"] },
        { "open": "--[[", "close": "]]", "notIn": ["string"] }
    ],
    "surroundingPairs": [
        { "open": "{", "close": "}" },
        { "open": "[", "close": "]" },
        { "open": "(", "close": ")" },
        { "open": "\"", "close": "\"" },
        { "open": "'", "close": "'" },
        { "open": "`", "close": "`" }
    ],
    "colorizedBracketPairs": [
        ["{", "}"],
        ["[", "]"],
        ["(", ")"]
    ],
    "folding": {
        "markers": {
            "start": "^\\s*--\\s*#?region\\b|^\\s*--\\s*={3,}",
            "end": "^\\s*--\\s*#?endregion\\b|^\\s*--\\s*={3,}"
        },
        "offSide": false
    },
    "wordPattern": "[a-zA-Z_]\\w*",
    "indentationRules": {
        "increaseIndentPattern": "^\\s*(else|elseif|for|if|while|repeat|function|do)\\b.*(?:then|do)?\\s*$|\\{\\s*$|\\b(async\\s+function)\\b.*$",
        "decreaseIndentPattern": "^\\s*(end|else|elseif|until)\\b|^\\s*\\}"
    },
    "onEnterRules": [
        {
            "beforeText": "^\\s*--",
            "action": {
                "indent": "none",
                "appendText": "-- "
            }
        },
        {
            "beforeText": "\\b(function|if|for|while|repeat|else|elseif|do)\\b.*$",
            "afterText": "^\\s*end\\b",
            "action": {
                "indent": "indent"
            }
        },
        {
            "beforeText": "\\b(function|if|for|while|repeat|else|elseif|do)\\b.*$",
            "action": {
                "indent": "indent"
            }
        },
        {
            "beforeText": "\\bend\\b",
            "action": {
                "indent": "outdent"
            }
        }
    ]
}
