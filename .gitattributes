# --- Default: auto-detect text files, normalize line endings ---
* text=auto

# --- Source files: always LF (prevents CRLF bugs in string literals) ---
*.c  text eol=lf
*.h  text eol=lf
*.n  text eol=lf
*.m  text eol=lf

# --- Linguist: language detection ---
# Nova isn't in GitHub Linguist yet — override so the repo doesn't show "Lua"
*.n  linguist-language=Nova
*.m  linguist-language=Nova

# --- Linguist: vendored / generated (exclude from language stats) ---
src/zorya/sqlite3.c   linguist-vendored
src/zorya/sqlite3.h   linguist-vendored
docs/**               linguist-documentation
dev/**                linguist-documentation
*.md                  linguist-documentation
